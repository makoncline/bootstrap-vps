# Copy this file to bootstrap/hosts/.env.production and fill in secrets before running.

# Public IPv4 of the server. Get this from the Hetzner server overview or Primary IP page.
HOST_PUBLIC_IPV4=203.0.113.10

# Public IPv6 of the server, if you want IPv6 enabled. Get this from Hetzner. Leave blank if unused.
HOST_PUBLIC_IPV6=2001:db8::10

# Linux hostname to set on the server. You choose this; usually match your Hetzner server name.
HOSTNAME=server-name

# One-off or reusable Tailscale auth key used only to join this server to your tailnet.
# Create it in the Tailscale admin console under Settings or Keys.
TAILSCALE_AUTHKEY=

# Name this server should register as in Tailscale. Usually the same as HOSTNAME.
TAILSCALE_HOSTNAME=server-name

# Cloudflare tunnel token for the dedicated tunnel you create for this server.
# In Cloudflare Zero Trust -> Networks/Access -> Tunnels -> open the tunnel -> Add a replica -> copy the token.
TUNNEL_TOKEN=

# UUID of that Cloudflare tunnel. Found on the tunnel details page in Cloudflare Zero Trust.
TUNNEL_ID=

# One concrete hostname routed through this tunnel for the sample whoami smoke check.
# Must be covered by TUNNEL_HOSTNAMES below.
SMOKE_HOSTNAME=whoami.example.com

# Comma-separated exact hostnames or wildcards that should point at this server's tunnel.
# Examples: *.makon.dev,*.daylilycatalog.com,app.example.com
TUNNEL_HOSTNAMES=*.example.com,*.example.net

# Cloudflare account ID that owns the tunnel and the DNS zones.
# Find it in the Cloudflare dashboard sidebar/account overview.
CF_ACCOUNT_ID=

# Cloudflare API token used by the local helper to sync tunnel ingress and DNS routes.
# Give it Account Cloudflare Tunnel Edit and Zone DNS Edit for the relevant account/zones.
CF_API_TOKEN=

# Comma-separated zone-name:zone-id pairs for every zone referenced by TUNNEL_HOSTNAMES.
# Zone IDs are on each zone's overview/API page in Cloudflare.
CF_ZONE_MAP=example.com:,example.net:

# Optional Telegram bot token for bootstrap health alerts.
# Create a bot with BotFather in Telegram and copy the HTTP API token.
TELEGRAM_BOT_TOKEN=

# Optional Telegram chat ID that should receive server alerts from the healthcheck timer.
# Send a message to the bot from your personal account or a group, then inspect the bot update payload
# to get that raw numeric chat ID. Do not use the bot's own ID here.
TELEGRAM_CHAT_ID=

# Optional disk usage percentage threshold for alerts on `/`. Defaults to 85 if left blank.
HEALTHCHECK_DISK_PCT=85
